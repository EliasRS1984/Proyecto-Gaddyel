{
  "redirects": [
    {
      "source": "/nuestro-proceso",
      "destination": "/proceso",
      "permanent": true
    },
    {
      "source": "/sobre-gaddyel",
      "destination": "/nosotros",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build"
}
